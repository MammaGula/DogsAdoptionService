@* @using DogsAdoptionService
@using DogsAdoptionService.Models *@


@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@model DogsAdoptionService.ViewModels.DogDetailsViewModel

@{
    ViewData["Title"] = "Dog Details";
}

<h2>@Model.Name</h2>

<div class="row">
    <div class="col-md-6">
        <img src="~/Images/@Model.Image" class="img-fluid" alt="@Model.Name" style="max-height: 500px; object-fit: cover; width: 100%;" />
    </div>
    <div class="col-md-6">
        <h4>Info</h4>
        <p><strong>Cuteness:</strong> @Model.Cuteness/10</p>
        <p><strong>Temperament:</strong> @Model.Temperament/10</p>
        <p><strong>Favorite Food:</strong> @Model.FavFood</p>
        <p><strong>Favorite Toy:</strong> @Model.FavToy</p>

        @if (!Model.IsAdopted)
        {
            <a class="btn btn-success" asp-controller="Dogs" asp-action="Adopt" asp-route-id="@Model.Id">
                🏡 Adopt this dog!
            </a>
        }
        else
        {
            <span class="badge bg-secondary">Already Adopted</span>
        }

        <a class="btn btn-secondary" asp-controller="Dogs" asp-action="Index">
            ← Back to list
        </a>
    </div>
</div>