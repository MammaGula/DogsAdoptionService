@model DogsAdoptionService.ViewModels.DogDetailsViewModel

@{
    ViewData["Title"] = "Adoption Success!";
}

<div class="text-center">
    <h1>🎉 Congratulations!</h1>
    <h2>You've adopted @Model.Name!</h2>
    
    <div class="my-4">
        <img src="~/Images/@Model.Image" alt="@Model.Name" style="max-height: 400px; border-radius: 10px;" />
    </div>
    
    <div class="alert alert-success">
        <h4>Welcome to your new family, @Model.Name! 🐕❤️</h4>
        <p>Don't forget their favorite food: <strong>@Model.FavFood</strong></p>
        <p>And their favorite toy: <strong>@Model.FavToy</strong></p>
    </div>
    
    <a class="btn btn-primary btn-lg" asp-controller="Dogs" asp-action="Index">
        See more dogs
    </a>
    <a class="btn btn-secondary btn-lg" asp-controller="Home" asp-action="Index">
        Go to Home
    </a>
</div>

@* 
- asp-for : Binding input with prop. in Model
- asp-action : Which method in controller to send data to
- asp-controller : Which controller to send data to (optional if sending to same controller)
- asp-route- : send data as route parameter (optional, can also send as query string or form data)
- asp-validation-for : for validation messages (not used in this example, but useful for showing validation errors)
- asp-validation-summary : for showing summary of validation errors (not used in this example, but useful for showing all validation errors in one place)
- form-asp-action : create form sending to action
- a asp-action : create link sending to action


*@