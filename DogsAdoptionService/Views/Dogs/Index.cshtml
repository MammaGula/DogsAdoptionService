@model IEnumerable<DogsAdoptionService.ViewModels.DogListViewModel>

@{
    ViewData["Title"] = "Dogs Available for Adoption";
}

<h1>🐕 Dogs Available for Adoption</h1>

<div class="row">
    @foreach (var dog in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card">
                <img src="~/Images/@dog.Image" class="card-img-top" alt="@dog.Name" style="height: 250px; object-fit: cover;" />
                <div class="card-body">
                    <h5 class="card-title">@dog.Name</h5>
                    <p class="card-text">
                        <strong>Cuteness:</strong> @dog.Cuteness/10
                    </p>
                    
                    @if (dog.IsAdopted)
                    {
                        <span class="badge bg-secondary">Already Adopted</span>
                    }
                    else
                    {
                        <a asp-controller="Dogs" asp-action="Details" asp-route-id="@dog.Id" class="btn btn-primary">View Details</a>
                    }
                </div>
            </div>
        </div>
    }
</div>



